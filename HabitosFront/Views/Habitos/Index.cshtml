@model List<HabitosFront.Models.HabitoViewModel>
@*
    @model — define qual tipo de dado esta View recebe do Controller.
    Aqui é uma lista de HabitoViewModel, passada pelo Index() do Controller.
*@

@{
    ViewData["Title"] = "Meus Hábitos";
    // Conta quantos estão concluídos para o resumo
    var total = Model.Count;
    var concluidos = Model.Count(h => h.Concluido);
    var porcentagem = total > 0 ? (concluidos * 100 / total) : 0;
}

<!-- SEÇÃO HERO — resumo do progresso do dia -->
<div class="hero-section">
    <div class="row align-items-center">
        <div class="col-md-8">
            <h1 class="fw-bold mb-1">
                <i class="bi bi-sun me-2"></i>Seus Hábitos de Hoje
            </h1>
            <p class="mb-3 opacity-75">
                @concluidos de @total hábitos concluídos
            </p>
            <!-- Barra de progresso -->
            <div class="progress" style="height: 10px; border-radius: 10px;">
                <div class="progress-bar bg-white"
                     style="width: @porcentagem%; border-radius: 10px;">
                </div>
            </div>
        </div>
        <div class="col-md-4 text-end mt-3 mt-md-0">
            <!-- Botão de novo hábito no hero -->
            <a href="/Habitos/Create" class="btn btn-light btn-lg fw-bold rounded-pill">
                <i class="bi bi-plus-circle me-2"></i>Novo Hábito
            </a>
        </div>
    </div>
</div>

<!-- FILTROS -->
<div class="card mb-4 border-0 shadow-sm" style="border-radius:16px;">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <!-- Filtro por categoria -->
            <div class="col-md-4">
                <label class="form-label fw-semibold">
                    <i class="bi bi-tag me-1"></i>Categoria
                </label>
                <select name="categoria" class="form-select" onchange="this.form.submit()">
                    <option value="">Todas as categorias</option>
                    @foreach (var cat in (List<string>)ViewBag.Categorias)
                    {
                        <option value="@cat"
                                selected="@(ViewBag.CategoriaAtual == cat ? "selected" : null)">
                            @cat
                        </option>
                    }
                </select>
            </div>

            <!-- Filtro por status -->
            <div class="col-md-4">
                <label class="form-label fw-semibold">
                    <i class="bi bi-funnel me-1"></i>Status
                </label>
                <select name="concluido" class="form-select" onchange="this.form.submit()">
                    <option value="">Todos</option>
                    <option value="false" selected="@(ViewBag.ConcluidoAtual == false ? "selected" : null)">
                        Pendentes
                    </option>
                    <option value="true" selected="@(ViewBag.ConcluidoAtual == true ? "selected" : null)">
                        Concluídos
                    </option>
                </select>
            </div>

            <!-- Botão limpar filtros -->
            <div class="col-md-4">
                <a href="/" class="btn btn-outline-secondary w-100">
                    <i class="bi bi-x-circle me-1"></i>Limpar Filtros
                </a>
            </div>
        </form>
    </div>
</div>

<!-- LISTAGEM DE HÁBITOS -->
@if (!Model.Any())
{
    <!-- Estado vazio — quando não há hábitos -->
    <div class="text-center py-5">
        <div style="font-size: 4rem;">🌱</div>
        <h4 class="mt-3 text-muted">Nenhum hábito encontrado</h4>
        <p class="text-muted">Comece criando seu primeiro hábito!</p>
        <a href="/Habitos/Create" class="btn btn-primary rounded-pill px-4">
            <i class="bi bi-plus-circle me-2"></i>Criar Hábito
        </a>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var habito in Model)
        {
            <!-- Cada hábito é um card -->
            <div class="col-md-6 col-lg-4">
                <div class="card card-habito h-100 @(habito.Concluido ? "concluido" : "pendente")"
                     id="card-@habito.Id">
                    <div class="card-body p-4">

                        <!-- Cabeçalho do card: ícone + nome -->
                        <div class="d-flex align-items-center mb-3">
                            <span class="icone-habito me-3">@habito.Icone</span>
                            <div>
                                <h5 class="card-title mb-0 fw-bold">@habito.Nome</h5>
                                <!-- Badge da categoria -->
                                <span class="badge bg-primary bg-opacity-10 text-primary badge-categoria">
                                    @habito.Categoria
                                </span>
                            </div>
                        </div>

                        <!-- Descrição (se houver) -->
                        @if (!string.IsNullOrEmpty(habito.Descricao))
                        {
                            <p class="card-text text-muted small">@habito.Descricao</p>
                        }

                        <!-- Status atual -->
                        <div class="mb-3">
                            @if (habito.Concluido)
                            {
                                <span class="badge bg-success">
                                    <i class="bi bi-check-circle me-1"></i>Concluído
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">
                                    <i class="bi bi-clock me-1"></i>Pendente
                                </span>
                            }
                        </div>

                        <!-- Botões de ação -->
                        <div class="d-flex gap-2 flex-wrap">

                            <!-- Botão Toggle (AJAX) — alterna status sem recarregar a página -->
                            <button class="btn btn-sm btn-toggle
                                           @(habito.Concluido ? "btn-outline-success" : "btn-success")"
                                    onclick="toggleHabito(@habito.Id)">
                                <i class="bi @(habito.Concluido ? "bi-arrow-counterclockwise" : "bi-check-lg") me-1"></i>
                                @(habito.Concluido ? "Desfazer" : "Concluir")
                            </button>

                            <!-- Botão Editar -->
                            <a href="/Habitos/Edit/@habito.Id"
                               class="btn btn-sm btn-outline-primary btn-toggle">
                                <i class="bi bi-pencil me-1"></i>Editar
                            </a>

                            <!-- Botão Excluir (formulário POST) -->
                            <form method="post" action="/Habitos/Delete/@habito.Id"
                                  onsubmit="return confirm('Excluir este hábito?')">
                                @Html.AntiForgeryToken()
                                @* Token de segurança anti-CSRF *@
                                <button type="submit" class="btn btn-sm btn-outline-danger btn-toggle">
                                    <i class="bi bi-trash me-1"></i>Excluir
                                </button>
                            </form>
                        </div>

                        <!-- Data de criação -->
                        <small class="text-muted d-block mt-3">
                            <i class="bi bi-calendar3 me-1"></i>
                            Criado em @habito.CriadoEm.ToString("dd/MM/yyyy")
                        </small>
                    </div>
                </div>
            </div>
        }
    </div>
}

@section Scripts {
<script>
    // Função para alternar o status de um hábito via AJAX
    // AJAX = chama o servidor sem recarregar a página inteira
    async function toggleHabito(id) {
        try {
            // Chama o nosso Controller front (que chama a API)
            const response = await fetch(`/Habitos/Toggle/${id}`, {
                method: 'POST',
                headers: {
                    // Token de segurança (obrigatório em POST no ASP.NET Core)
                    'RequestVerificationToken': document.querySelector(
                        'input[name="__RequestVerificationToken"]'
                    )?.value || ''
                }
            });

            if (response.ok) {
                // Recarrega a página para mostrar o novo status
                // Em versão futura, poderíamos atualizar só o card sem recarregar
                location.reload();
            } else {
                alert('Erro ao atualizar hábito. Tente novamente.');
            }
        } catch (error) {
            console.error('Erro:', error);
            alert('Erro de conexão. Verifique se a API está rodando.');
        }
    }
</script>
<!-- Token anti-CSRF disponível para o JavaScript acima -->
@Html.AntiForgeryToken()
}